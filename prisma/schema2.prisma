generator client {
  provider = "prisma-client-js"
  output   = "generated/srx-app-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL2")
}

model affiliate_accounts {
  id                      BigInt                             @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                 BigInt                             @unique(map: "uq_affiliate_accounts_user_id") @db.UnsignedBigInt
  application_id          BigInt?                            @unique(map: "uq_affiliate_accounts_application_id") @db.UnsignedBigInt
  affiliate_code          String                             @unique(map: "uq_affiliate_accounts_affiliate_code") @db.VarChar(30)
  status                  affiliate_accounts_status          @default(active)
  commission_type         affiliate_accounts_commission_type @default(percent)
  commission_rate         Decimal                            @default(5.00) @db.Decimal(5, 2)
  cookie_duration_days    Int                                @default(30) @db.UnsignedInt
  total_clicks            Int                                @default(0) @db.UnsignedInt
  total_orders            Int                                @default(0) @db.UnsignedInt
  approved_at             DateTime?                          @db.DateTime(0)
  created_at              DateTime                           @default(now()) @db.DateTime(0)
  updated_at              DateTime                           @default(now()) @db.DateTime(0)
  affiliate_applications  affiliate_applications?            @relation(fields: [application_id], references: [id], map: "fk_affiliate_accounts_application")
  users                   users                              @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_affiliate_accounts_user")
  affiliate_bank_accounts affiliate_bank_accounts?
  affiliate_clicks        affiliate_clicks[]
  affiliate_links         affiliate_links[]
  affiliate_payouts       affiliate_payouts[]
  affiliate_referrals     affiliate_referrals[]
  orders                  orders[]

  @@index([status], map: "idx_affiliate_accounts_status")
}

model affiliate_applications {
  id                                                      BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                                                 BigInt                        @unique(map: "uq_affiliate_applications_user_id") @db.UnsignedBigInt
  legal_full_name                                         String?                       @db.VarChar(150)
  permanent_address                                       String?                       @db.VarChar(255)
  national_id_number                                      String?                       @db.VarChar(30)
  contact_email                                           String?                       @db.VarChar(255)
  gender                                                  affiliate_applications_gender @default(prefer_not_to_say)
  facebook_url                                            String?                       @db.VarChar(500)
  tiktok_url                                              String?                       @db.VarChar(500)
  contact_phone                                           String?                       @db.VarChar(20)
  social_channel                                          String?                       @db.VarChar(255)
  website_url                                             String?                       @db.VarChar(500)
  promotion_plan                                          String?                       @db.Text
  status                                                  affiliate_applications_status @default(pending)
  review_note                                             String?                       @db.Text
  reviewed_by_user_id                                     BigInt?                       @db.UnsignedBigInt
  reviewed_at                                             DateTime?                     @db.DateTime(0)
  created_at                                              DateTime                      @default(now()) @db.DateTime(0)
  updated_at                                              DateTime                      @default(now()) @db.DateTime(0)
  affiliate_accounts                                      affiliate_accounts?
  users_affiliate_applications_reviewed_by_user_idTousers users?                        @relation("affiliate_applications_reviewed_by_user_idTousers", fields: [reviewed_by_user_id], references: [id], map: "fk_affiliate_applications_reviewed_by")
  users_affiliate_applications_user_idTousers             users                         @relation("affiliate_applications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, map: "fk_affiliate_applications_user")

  @@index([reviewed_by_user_id], map: "fk_affiliate_applications_reviewed_by")
  @@index([status], map: "idx_affiliate_applications_status")
}

model affiliate_bank_accounts {
  id                   BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  affiliate_account_id BigInt             @unique(map: "uq_affiliate_bank_accounts_account_id") @db.UnsignedBigInt
  account_holder_name  String             @db.VarChar(150)
  bank_name            String             @db.VarChar(150)
  bank_branch          String?            @db.VarChar(150)
  account_number       String             @db.VarChar(50)
  created_at           DateTime           @default(now()) @db.DateTime(0)
  updated_at           DateTime           @default(now()) @db.DateTime(0)
  affiliate_accounts   affiliate_accounts @relation(fields: [affiliate_account_id], references: [id], onDelete: Cascade, map: "fk_affiliate_bank_accounts_account")

  @@index([bank_name], map: "idx_affiliate_bank_accounts_bank_name")
}

model affiliate_clicks {
  id                   BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  affiliate_account_id BigInt                @db.UnsignedBigInt
  affiliate_link_id    BigInt?               @db.UnsignedBigInt
  visitor_token        String?               @db.Char(64)
  customer_user_id     BigInt?               @db.UnsignedBigInt
  ip_address           String?               @db.VarChar(45)
  user_agent           String?               @db.VarChar(500)
  referrer_url         String?               @db.VarChar(500)
  landing_url          String?               @db.VarChar(500)
  converted_order_id   BigInt?               @db.UnsignedBigInt
  clicked_at           DateTime              @default(now()) @db.DateTime(0)
  affiliate_accounts   affiliate_accounts    @relation(fields: [affiliate_account_id], references: [id], onDelete: Cascade, map: "fk_affiliate_clicks_account")
  users                users?                @relation(fields: [customer_user_id], references: [id], map: "fk_affiliate_clicks_customer_user")
  affiliate_links      affiliate_links?      @relation(fields: [affiliate_link_id], references: [id], map: "fk_affiliate_clicks_link")
  orders               orders?               @relation(fields: [converted_order_id], references: [id], map: "fk_affiliate_clicks_order")
  affiliate_referrals  affiliate_referrals[]

  @@index([affiliate_account_id], map: "idx_affiliate_clicks_account_id")
  @@index([clicked_at], map: "idx_affiliate_clicks_clicked_at")
  @@index([converted_order_id], map: "idx_affiliate_clicks_converted_order_id")
  @@index([customer_user_id], map: "idx_affiliate_clicks_customer_user_id")
  @@index([affiliate_link_id], map: "idx_affiliate_clicks_link_id")
  @@index([visitor_token], map: "idx_affiliate_clicks_visitor_token")
}

model affiliate_links {
  id                   BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  affiliate_account_id BigInt                      @db.UnsignedBigInt
  campaign_name        String                      @db.VarChar(150)
  code                 String                      @unique(map: "uq_affiliate_links_code") @db.VarChar(40)
  target_type          affiliate_links_target_type @default(homepage)
  target_url           String                      @db.VarChar(500)
  source               String?                     @db.VarChar(100)
  medium               String?                     @db.VarChar(100)
  content              String?                     @db.VarChar(100)
  is_active            Boolean                     @default(true)
  created_at           DateTime                    @default(now()) @db.DateTime(0)
  updated_at           DateTime                    @default(now()) @db.DateTime(0)
  affiliate_clicks     affiliate_clicks[]
  affiliate_accounts   affiliate_accounts          @relation(fields: [affiliate_account_id], references: [id], onDelete: Cascade, map: "fk_affiliate_links_account")
  affiliate_referrals  affiliate_referrals[]
  orders               orders[]

  @@index([affiliate_account_id], map: "idx_affiliate_links_account_id")
  @@index([is_active], map: "idx_affiliate_links_is_active")
  @@index([target_type], map: "idx_affiliate_links_target_type")
}

model affiliate_payout_items {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  payout_id           BigInt              @db.UnsignedBigInt
  referral_id         BigInt              @unique(map: "uq_affiliate_payout_items_referral_id") @db.UnsignedBigInt
  amount              Decimal             @db.Decimal(12, 2)
  created_at          DateTime            @default(now()) @db.DateTime(0)
  affiliate_payouts   affiliate_payouts   @relation(fields: [payout_id], references: [id], onDelete: Cascade, map: "fk_affiliate_payout_items_payout")
  affiliate_referrals affiliate_referrals @relation(fields: [referral_id], references: [id], map: "fk_affiliate_payout_items_referral")

  @@index([payout_id], map: "idx_affiliate_payout_items_payout_id")
}

model affiliate_payouts {
  id                     BigInt                           @id @default(autoincrement()) @db.UnsignedBigInt
  affiliate_account_id   BigInt                           @db.UnsignedBigInt
  payout_number          String                           @unique(map: "uq_affiliate_payouts_payout_number") @db.VarChar(30)
  period_start           DateTime                         @db.Date
  period_end             DateTime                         @db.Date
  total_commission       Decimal                          @default(0.00) @db.Decimal(12, 2)
  payout_status          affiliate_payouts_payout_status  @default(pending)
  payment_method         affiliate_payouts_payment_method @default(bank_transfer)
  paid_at                DateTime?                        @db.DateTime(0)
  notes                  String?                          @db.Text
  created_at             DateTime                         @default(now()) @db.DateTime(0)
  updated_at             DateTime                         @default(now()) @db.DateTime(0)
  affiliate_payout_items affiliate_payout_items[]
  affiliate_accounts     affiliate_accounts               @relation(fields: [affiliate_account_id], references: [id], map: "fk_affiliate_payouts_account")

  @@index([affiliate_account_id], map: "idx_affiliate_payouts_account_id")
  @@index([payout_status], map: "idx_affiliate_payouts_status")
}

model affiliate_referrals {
  id                     BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  affiliate_account_id   BigInt                              @db.UnsignedBigInt
  affiliate_link_id      BigInt?                             @db.UnsignedBigInt
  affiliate_click_id     BigInt?                             @db.UnsignedBigInt
  order_id               BigInt                              @unique(map: "uq_affiliate_referrals_order_id") @db.UnsignedBigInt
  customer_user_id       BigInt?                             @db.UnsignedBigInt
  commission_type        affiliate_referrals_commission_type @default(percent)
  commission_rate        Decimal                             @db.Decimal(5, 2)
  commission_base_amount Decimal                             @db.Decimal(12, 2)
  commission_amount      Decimal                             @db.Decimal(12, 2)
  status                 affiliate_referrals_status          @default(pending)
  approved_at            DateTime?                           @db.DateTime(0)
  paid_at                DateTime?                           @db.DateTime(0)
  notes                  String?                             @db.Text
  created_at             DateTime                            @default(now()) @db.DateTime(0)
  updated_at             DateTime                            @default(now()) @db.DateTime(0)
  affiliate_payout_items affiliate_payout_items?
  affiliate_accounts     affiliate_accounts                  @relation(fields: [affiliate_account_id], references: [id], map: "fk_affiliate_referrals_account")
  affiliate_clicks       affiliate_clicks?                   @relation(fields: [affiliate_click_id], references: [id], map: "fk_affiliate_referrals_click")
  users                  users?                              @relation(fields: [customer_user_id], references: [id], map: "fk_affiliate_referrals_customer_user")
  affiliate_links        affiliate_links?                    @relation(fields: [affiliate_link_id], references: [id], map: "fk_affiliate_referrals_link")
  orders                 orders                              @relation(fields: [order_id], references: [id], map: "fk_affiliate_referrals_order")

  @@index([customer_user_id], map: "fk_affiliate_referrals_customer_user")
  @@index([affiliate_account_id], map: "idx_affiliate_referrals_account_id")
  @@index([affiliate_click_id], map: "idx_affiliate_referrals_click_id")
  @@index([affiliate_link_id], map: "idx_affiliate_referrals_link_id")
  @@index([status], map: "idx_affiliate_referrals_status")
}

model article_categories {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name        String   @db.VarChar(100)
  slug        String   @unique(map: "uq_article_categories_slug") @db.VarChar(120)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @db.DateTime(0)
  posts       posts[]

  @@index([is_active], map: "idx_article_categories_is_active")
  @@index([sort_order], map: "idx_article_categories_sort_order")
}

model attribute_values {
  id                       BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  attribute_id             BigInt                     @db.UnsignedBigInt
  value                    String                     @db.VarChar(100)
  slug                     String                     @db.VarChar(120)
  sort_order               Int                        @default(0)
  created_at               DateTime                   @default(now()) @db.DateTime(0)
  updated_at               DateTime                   @default(now()) @db.DateTime(0)
  attributes               attributes                 @relation(fields: [attribute_id], references: [id], onDelete: Cascade, map: "fk_attribute_values_attribute")
  product_attribute_values product_attribute_values[]
  variant_attribute_values variant_attribute_values[]

  @@unique([attribute_id, slug], map: "uq_attribute_values_attribute_slug")
  @@index([attribute_id], map: "idx_attribute_values_attribute_id")
}

model attributes {
  id                       BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  code                     String                     @unique(map: "uq_attributes_code") @db.VarChar(50)
  name                     String                     @db.VarChar(100)
  input_type               attributes_input_type      @default(select)
  is_filterable            Boolean                    @default(true)
  is_variant_axis          Boolean                    @default(false)
  sort_order               Int                        @default(0)
  created_at               DateTime                   @default(now()) @db.DateTime(0)
  updated_at               DateTime                   @default(now()) @db.DateTime(0)
  attribute_values         attribute_values[]
  product_attribute_values product_attribute_values[]
  variant_attribute_values variant_attribute_values[]

  @@index([is_filterable], map: "idx_attributes_is_filterable")
  @@index([is_variant_axis], map: "idx_attributes_is_variant_axis")
}

model brands {
  id          BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  name        String     @db.VarChar(120)
  slug        String     @unique(map: "uq_brands_slug") @db.VarChar(150)
  description String?    @db.Text
  logo_url    String?    @db.VarChar(500)
  website_url String?    @db.VarChar(500)
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.DateTime(0)
  updated_at  DateTime   @default(now()) @db.DateTime(0)
  products    products[]

  @@index([is_active], map: "idx_brands_is_active")
}

model banners {
  id               BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  title            String            @db.VarChar(150)
  slug             String            @unique(map: "uq_banners_slug") @db.VarChar(180)
  description      String?           @db.Text
  image_url        String            @db.VarChar(500)
  mobile_image_url String?           @db.VarChar(500)
  alt_text         String?           @db.VarChar(255)
  button_label     String?           @db.VarChar(80)
  link_type        banners_link_type @default(custom)
  link_target      String?           @db.VarChar(500)
  position         banners_position  @default(homepage_hero)
  open_in_new_tab  Boolean           @default(false)
  sort_order       Int               @default(0)
  starts_at        DateTime?         @db.DateTime(0)
  ends_at          DateTime?         @db.DateTime(0)
  is_active        Boolean           @default(true)
  created_at       DateTime          @default(now()) @db.DateTime(0)
  updated_at       DateTime          @default(now()) @db.DateTime(0)

  @@index([is_active], map: "idx_banners_is_active")
  @@index([position], map: "idx_banners_position")
  @@index([sort_order], map: "idx_banners_sort_order")
  @@index([starts_at], map: "idx_banners_starts_at")
  @@index([ends_at], map: "idx_banners_ends_at")
}

model ladipage_events {
  id                    BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  name                  String                 @db.VarChar(150)
  slug                  String                 @unique(map: "uq_ladipage_events_slug") @db.VarChar(180)
  event_name            String                 @db.VarChar(180)
  legacy_template_slug  String?                @db.VarChar(255)
  site_key              String                 @default("srx-event-site") @db.VarChar(80)
  public_base_url       String?                @db.VarChar(500)
  public_path           String?                @db.VarChar(255)
  status                ladipage_events_status @default(published)
  is_active             Boolean                @default(true)
  template_style        String                 @default("default") @db.VarChar(50)
  sort_order            Int                    @default(0)
  config_json           Json
  published_config_json Json?
  published_at          DateTime?              @db.DateTime(0)
  last_synced_at        DateTime?              @db.DateTime(0)
  created_by            String?                @db.VarChar(255)
  updated_by            String?                @db.VarChar(255)
  created_at            DateTime               @default(now()) @db.DateTime(0)
  updated_at            DateTime               @default(now()) @db.DateTime(0)

  @@index([site_key], map: "idx_ladipage_events_site_key")
  @@index([status], map: "idx_ladipage_events_status")
  @@index([is_active], map: "idx_ladipage_events_is_active")
  @@index([sort_order], map: "idx_ladipage_events_sort_order")
  @@index([published_at], map: "idx_ladipage_events_published_at")
}

model discount_code_category_links {
  discount_code_id    BigInt             @db.UnsignedBigInt
  category_id         BigInt             @db.UnsignedBigInt
  created_at          DateTime           @default(now()) @db.DateTime(0)
  discount_codes      discount_codes     @relation(fields: [discount_code_id], references: [id], onDelete: Cascade, map: "fk_discount_code_category_links_code")
  product_categories  product_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, map: "fk_discount_code_category_links_category")

  @@id([discount_code_id, category_id])
  @@index([category_id], map: "idx_discount_code_category_links_category_id")
}

model discount_code_product_links {
  discount_code_id BigInt         @db.UnsignedBigInt
  product_id       BigInt         @db.UnsignedBigInt
  created_at       DateTime       @default(now()) @db.DateTime(0)
  discount_codes   discount_codes @relation(fields: [discount_code_id], references: [id], onDelete: Cascade, map: "fk_discount_code_product_links_code")
  products         products       @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_discount_code_product_links_product")

  @@id([discount_code_id, product_id])
  @@index([product_id], map: "idx_discount_code_product_links_product_id")
}

model discount_code_redemptions {
  id               BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  discount_code_id BigInt                         @db.UnsignedBigInt
  order_id         BigInt                         @db.UnsignedBigInt
  user_id          BigInt?                        @db.UnsignedBigInt
  discount_amount  Decimal                        @default(0.00) @db.Decimal(12, 2)
  status           discount_code_redemptions_status @default(applied)
  notes            String?                        @db.Text
  redeemed_at      DateTime                       @default(now()) @db.DateTime(0)
  created_at       DateTime                       @default(now()) @db.DateTime(0)
  discount_codes   discount_codes                 @relation(fields: [discount_code_id], references: [id], onDelete: Cascade, map: "fk_discount_code_redemptions_code")
  orders           orders                         @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_discount_code_redemptions_order")
  users            users?                         @relation(fields: [user_id], references: [id], map: "fk_discount_code_redemptions_user")

  @@unique([discount_code_id, order_id], map: "uq_discount_code_redemptions_code_order")
  @@index([order_id], map: "idx_discount_code_redemptions_order_id")
  @@index([status], map: "idx_discount_code_redemptions_status")
  @@index([user_id], map: "idx_discount_code_redemptions_user_id")
}

model discount_codes {
  id                           BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  code                         String                         @unique(map: "uq_discount_codes_code") @db.VarChar(50)
  name                         String                         @db.VarChar(150)
  description                  String?                        @db.Text
  discount_type                discount_codes_discount_type   @default(percentage)
  discount_value               Decimal                        @default(0.00) @db.Decimal(12, 2)
  max_discount_amount          Decimal?                       @db.Decimal(12, 2)
  min_order_amount             Decimal?                       @db.Decimal(12, 2)
  total_usage_limit            Int?                           @db.UnsignedInt
  per_user_limit               Int?                           @db.UnsignedInt
  scope_type                   discount_codes_scope_type      @default(all_orders)
  starts_at                    DateTime?                      @db.DateTime(0)
  ends_at                      DateTime?                      @db.DateTime(0)
  is_active                    Boolean                        @default(true)
  created_by_user_id           BigInt?                        @db.UnsignedBigInt
  created_at                   DateTime                       @default(now()) @db.DateTime(0)
  updated_at                   DateTime                       @default(now()) @db.DateTime(0)
  discount_code_category_links discount_code_category_links[]
  discount_code_product_links  discount_code_product_links[]
  discount_code_redemptions    discount_code_redemptions[]
  users                        users?                         @relation(fields: [created_by_user_id], references: [id], map: "fk_discount_codes_created_by")

  @@index([created_by_user_id], map: "idx_discount_codes_created_by_user_id")
  @@index([ends_at], map: "idx_discount_codes_ends_at")
  @@index([is_active], map: "idx_discount_codes_is_active")
  @@index([scope_type], map: "idx_discount_codes_scope_type")
  @@index([starts_at], map: "idx_discount_codes_starts_at")
}

model email_verification_tokens {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt    @db.UnsignedBigInt
  token      String    @unique(map: "uq_email_verification_tokens_token") @db.Char(64)
  expires_at DateTime  @db.DateTime(0)
  used_at    DateTime? @db.DateTime(0)
  created_at DateTime  @default(now()) @db.DateTime(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_email_verification_tokens_user")

  @@index([expires_at], map: "idx_email_verification_tokens_expires_at")
  @@index([user_id], map: "idx_email_verification_tokens_user_id")
}

model order_addresses {
  id              BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  order_id        BigInt                       @db.UnsignedBigInt
  address_type    order_addresses_address_type @default(shipping)
  recipient_name  String                       @db.VarChar(150)
  recipient_phone String                       @db.VarChar(20)
  country_code    String                       @default("VN") @db.Char(2)
  province        String                       @db.VarChar(100)
  district        String                       @db.VarChar(100)
  ward            String?                      @db.VarChar(100)
  address_line    String                       @db.VarChar(255)
  postal_code     String?                      @db.VarChar(20)
  created_at      DateTime                     @default(now()) @db.DateTime(0)
  orders          orders                       @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_order_addresses_order")

  @@unique([order_id, address_type], map: "uq_order_addresses_order_type")
}

model order_items {
  id               BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  order_id         BigInt            @db.UnsignedBigInt
  product_id       BigInt?           @db.UnsignedBigInt
  variant_id       BigInt?           @db.UnsignedBigInt
  sku              String?           @db.VarChar(100)
  product_name     String            @db.VarChar(200)
  variant_name     String?           @db.VarChar(200)
  unit_price       Decimal           @default(0.00) @db.Decimal(12, 2)
  quantity         Int               @default(1) @db.UnsignedInt
  discount_amount  Decimal           @default(0.00) @db.Decimal(12, 2)
  line_total       Decimal           @default(0.00) @db.Decimal(12, 2)
  created_at       DateTime          @default(now()) @db.DateTime(0)
