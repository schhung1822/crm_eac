# Use a single `.env` file for the whole app.
# The app supports both:
# 1. two-database mode: CRM and SRX use separate connections
# 2. one-database mode: CRM legacy tables live inside the SRX database
# In one-database mode, you can provide only the SRX vars below and the app
# will reuse that connection for the CRM legacy layer.
# If both CRM and SRX vars are present, the app will still prefer SRX for
# the CRM legacy layer so the old EAC tables can be read from the SRX DB.

# CRM database
# Optional when you only use one SRX database.
CRM_DB_HOST="127.0.0.1"
CRM_DB_PORT="3306"
CRM_DB_USER="crm_user"
CRM_DB_PASSWORD="change-me"
CRM_DB_NAME="crm_db"

# SRX database
SRX_DB_HOST="127.0.0.1"
SRX_DB_PORT="3306"
SRX_DB_USER="srx_user"
SRX_DB_PASSWORD="change-me"
SRX_DB_NAME="srx_db"

# Optional explicit URLs.
# Only use these if you want to provide full connection strings directly.
# If the password contains special characters like @ : / ? # or %,
# you should URL-encode it first.
# DATABASE_URL="mysql://crm_user:your%40password@127.0.0.1:3306/crm_db"
# DATABASE_URL2="mysql://srx_user:your%40password@127.0.0.1:3306/srx_db"

# JWT secret
JWT_SECRET="replace-with-a-long-random-secret"

# Optional for commercial CKEditor builds. Defaults to GPL when omitted.
# NEXT_PUBLIC_CKEDITOR_LICENSE_KEY=""

# Node environment
NODE_ENV="production"

# Order notifications from SRX website checkout
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="notifications@example.com"
SMTP_PASS="change-me"
SMTP_FROM_EMAIL="notifications@example.com"
SMTP_FROM_NAME="SRX Viet Nam"
LARK_WEBHOOK_URL="https://open.larksuite.com/open-apis/bot/v2/hook/replace-me"

# Optional shared secret between SRX_web and crm-eac for /api/srx/orders_web
# SRX_ORDERS_WEB_API_TOKEN="replace-with-a-long-random-secret"
# SRX_AFFILIATE_APPLICATIONS_WEB_API_TOKEN="replace-with-a-long-random-secret"
# SRX_LEAD_FORMS_WEB_API_TOKEN="replace-with-a-long-random-secret"

# Social publishing for SRX news posts
NEXT_PUBLIC_SITE_URL="https://example.com"
# SRX_PUBLIC_NEWS_URL_TEMPLATE="https://example.com/tin-tuc/{slug}"
SRX_FACEBOOK_PAGE_ID="1149491654916679"
SRX_FACEBOOK_PAGE_ACCESS_TOKEN="replace-with-facebook-page-token"
FACEBOOK_GRAPH_API_VERSION="v20.0"
ZALO_OA_ARTICLE_AUTHOR="SRX"
# ZALO_OA_ARTICLE_CREATE_URL="https://openapi.zalo.me/v2.0/article/create"
# ZALO_OA_ARTICLE_UPDATE_URL="https://openapi.zalo.me/v2.0/article/update"
# ZALO_OA_ARTICLE_DELETE_URL="https://openapi.zalo.me/v2.0/article/remove"
# ZALO_OA_ARTICLE_LIST_URL="https://openapi.zalo.me/v2.0/article/getlist"
