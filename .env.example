# Use a single `.env` file for the whole app, including both databases.
# Recommended: use named DB vars below. The app will build `DATABASE_URL`
# and `DATABASE_URL2` internally for Prisma at runtime.

# CRM database
CRM_DB_HOST="127.0.0.1"
CRM_DB_PORT="3306"
CRM_DB_USER="crm_user"
CRM_DB_PASSWORD="change-me"
CRM_DB_NAME="crm_db"

# Optional named fallback for SRX if you do not want to use DATABASE_URL2
SRX_DB_HOST="127.0.0.1"
SRX_DB_PORT="3306"
SRX_DB_USER="srx_user"
SRX_DB_PASSWORD="change-me"
SRX_DB_NAME="srx_db"

# Optional explicit URLs.
# Only use these if you want to provide full connection strings directly.
# If the password contains special characters like @ : / ? # or %,
# you should URL-encode it first.
# DATABASE_URL="mysql://crm_user:your%40password@127.0.0.1:3306/crm_db"
# DATABASE_URL2="mysql://srx_user:your%40password@127.0.0.1:3306/srx_db"

# JWT secret
JWT_SECRET="replace-with-a-long-random-secret"

# Optional for commercial CKEditor builds. Defaults to GPL when omitted.
# NEXT_PUBLIC_CKEDITOR_LICENSE_KEY=""

# Node environment
NODE_ENV="production"
